# Postgres
POSTGRES_USER=pstreview
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pstreview
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Backend
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false
STORAGE_ROOT=/data
BACKEND_CORS_ORIGINS=http://localhost
ENABLE_API_DOCS=false

# Frontend
VITE_API_BASE_URL=/api
# Host port the frontend is published on. Change this if 80 is already in
# use, or if `docker compose up` reports "port is already allocated" for it
# even though nothing appears to be listening (a known intermittent issue on
# some hosts -- install.sh retries automatically with a fallback port when
# this happens).
FRONTEND_PORT=80
